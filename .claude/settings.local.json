{
  "permissions": {
    "allow": [
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:news.hada.io)",
      "WebFetch(domain:www.mindstudio.ai)",
      "WebFetch(domain:medium.com)",
      "Bash(gh auth *)",
      "Bash(git --version)",
      "Bash(gh repo *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash([ -d \"wiki/$dir\" ])",
      "Bash(cp -r wiki/__TRACKED_VAR__/. wiki/투자/__TRACKED_VAR__/)",
      "Bash(rm -rf wiki/__TRACKED_VAR__)",
      "Bash([ -d \"sources/$dir\" ])",
      "Bash(cp -r sources/__TRACKED_VAR__/. sources/투자/__TRACKED_VAR__/)"
    ]
  }
}
